# Deployment mode: "proxy" (runs alongside Ollama) or "tracker" (central aggregator)
MODE=proxy

# Device name — identifies this machine in the tracker dashboard
DEVICE_NAME=default

# Central tracker URL (proxy mode only) — set to report metrics to a central node
# TRACKER_URL=http://tracker-node:11434

# Ollama actual host — move Ollama to port 11435 so the proxy can take over 11434
# (only used in proxy mode)
# Run: launchctl setenv OLLAMA_HOST "127.0.0.1:11435" then restart Ollama
OLLAMA_HOST=http://localhost:11435

# Proxy listens on 11434 so all existing apps work without changes
PROXY_PORT=11434

# Database path (default: ~/.ollama-tracker/usage.db)
DB_PATH=~/.ollama-tracker/usage.db
