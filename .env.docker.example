# Deployment mode: "proxy" (runs alongside Ollama) or "tracker" (central aggregator)
MODE=proxy

# Device name — identifies this machine in the tracker dashboard
DEVICE_NAME=default

# Central tracker URL (proxy mode only) — set to report metrics to a central node
# TRACKER_URL=http://tracker-node:11434

# Ollama host — use host.docker.internal so the container can reach Ollama on your machine
# (localhost inside Docker refers to the container, not your host)
OLLAMA_HOST=http://host.docker.internal:11435

# Timezone for stats bucketing
TIMEZONE=America/Los_Angeles
