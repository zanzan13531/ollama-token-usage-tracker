[Unit]
Description=Ollama Token Usage Tracker
After=network.target

[Service]
Type=simple
User=__USER__
WorkingDirectory=__PROJECT_DIR__
ExecStart=__VENV_BIN__/uvicorn app.main:app --host 0.0.0.0 --port 11434
Restart=always
RestartSec=5
Environment=PATH=__VENV_BIN__:/usr/bin:/bin

[Install]
WantedBy=multi-user.target
